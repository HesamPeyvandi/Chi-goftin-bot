# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
ADMIN_USER_ID=123456789

# AI providers (fallback order: Gemini -> Grok -> OpenRouter)
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=models/gemini-3.1-flash-lite

GROK_API_KEY=your_grok_api_key
GROK_MODEL=grok-4.3

OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openrouter/free

# Database
DATABASE_PATH=chi_goftin.db
DEFAULT_MESSAGE_HISTORY_LIMIT=1500

# Web server (used only as a keep-alive endpoint on free hosting tiers)
PORT=10000
